Algoritmo Suma_y_Resta
    Definir num1, num2, suma, resta Como Real
    
    Escribir "Ingresa el primer numero"
    Leer num1
    
    Escribir "Ingresa el segundo numero"
    Leer num2
    
    suma <- num1 + num2
    resta <- num1 - num2
    
    Escribir "La suma es ", suma
    Escribir "La resta es ", resta
FinAlgoritmo
