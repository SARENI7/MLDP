Algoritmo Area_Rectangulo
    Definir base, altura, area Como Real
    
    Escribir "Calculadora de Area de Rectangulo"
    Escribir "Ingresa la base:"
    Leer base
    
    Escribir "Ingresa la altura:"
    Leer altura
    
    area <- base * altura
    
    Escribir "El area es: ", area
FinAlgoritmo
